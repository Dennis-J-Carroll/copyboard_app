                },
                {
                    "label": "Media query",
                    "text": "@media (max-width: 768px) {\n  ${cursor}\n}"
                },
                {
                    "label": "Gradient",
                    "text": "background: linear-gradient(135deg, ${cursor}, ${cursor});"
                },
                {
                    "label": "Hover scale",
                    "text": "transition: all 0.3s ease;\n&:hover {\n  transform: scale(1.05);\n}"
                },
                {
                    "label": "Sticky top",
